generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cabin {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  address     String
  description String
  price       String
  guests      Int
  bedrooms    Int
  bathrooms   Int
  wifi        Boolean  @default(false)
  hotTub      Boolean  @default(false)
  lakeAccess  Boolean  @default(false)
  fireplace   Boolean  @default(false)
  bbq         Boolean  @default(false)
  airConditioning Boolean @default(false)
  fullKitchen Boolean  @default(false)
  washerDryer Boolean  @default(false)
  workspace   Boolean  @default(false)
  petFriendly Boolean  @default(false)
  selfCheckIn Boolean  @default(false)
  freeParking Boolean  @default(false)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  images      CabinImage[]
  reviews     Review[]
}

model CabinImage {
  id       String @id @default(cuid())
  url      String
  mediaType String @default("image")
  isHero   Boolean @default(false)
  position Int
  cabinId  String
  cabin    Cabin  @relation(fields: [cabinId], references: [id], onDelete: Cascade)
}

model Reservation {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  chalet      String
  startDate   String
  endDate     String
  comments    String
  createdAt   DateTime @default(now())
}

model Review {
  id               String   @id @default(cuid())
  reviewerName     String
  reviewerLocation String?
  title            String
  body             String
  rating           Int
  source           String   @default("direct")
  stayLabel        String?
  approved         Boolean  @default(true)
  featured         Boolean  @default(false)
  cabinId          String?
  cabin            Cabin?   @relation(fields: [cabinId], references: [id], onDelete: SetNull)
  imageUrls        String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
